# CurveLaunchpad deploy configuration. Everything has a sane default; override only if needed.

# Curve economics (defaults: 1 ether virtual reserve, 4 ether graduation, 1% fee, 50/50 split)
VIRTUAL_ETH=
GRAD_ETH=
FEE_BPS=
CREATOR_SHARE_BPS=

# Mainnet graduation router. Default = canonical Uniswap V2 Router02 on Base
# (0x4752ba5DBc23f44D87826276BF6Fd6b1C372aD24, verified onchain). Override for another v2 DEX.
ROUTER=

# Mainnet safety gate: the deploy script refuses to broadcast unless this equals "audited".
# Only set it after a completed security audit of CurveLaunchpad.
CONFIRM_MAINNET=
