BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional. When present, recent checks are persisted in Vercel KV.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Mainnet B20 creation is live by default (Base activated it 2026-07-09, verified onchain).
# Set to "false" only to force the pre-activation gate back on.
NEXT_PUBLIC_MAINNET_LIVE=

# CurveLaunchpad addresses (from contracts/script/CurveLaunchpad.s.sol broadcast).
# When set, Explore/coin/trade read live curve data; when empty Explore shows real Factory launches.
NEXT_PUBLIC_CURVE_ADDRESS_84532=
# Live on Base mainnet since 2026-07-09 (deploy tx by 0x1a25...e4d7). Set this in the Vercel env.
NEXT_PUBLIC_CURVE_ADDRESS_8453=0xd5a40a12B43761d255D141D11227e6Fce54b00fd
